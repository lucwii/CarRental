<!-- HERO -->
<section class="hero">
    <div class="hero-bg-grid"></div>
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
    <div class="hero-glow hero-glow-3"></div>

    <div class="hero-particles">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
    </div>

    <div class="hero-container">
        <div class="hero-content">
            <div class="hero-badge">
                <span class="hero-badge-dot"></span>
                Available Now
            </div>

            <h1 class="hero-title">
                <span class="hero-title-line"><span>Drive Your</span></span>
                <span class="hero-title-line"><span class="hero-title-gradient">Dream Car</span></span>
                <span class="hero-title-line"><span>Today.</span></span>
            </h1>

            <p class="hero-description">
                Premium vehicles at unbeatable prices. From city commutes to luxury getaways,
                find the perfect ride for every journey.
            </p>

            <div class="hero-actions">
                <a href="#cars" class="btn-hero-primary">
                    Explore Fleet
                    <span class="btn-arrow">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </span>
                </a>
                <a href="#how-it-works" class="btn-hero-secondary">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
                    </svg>
                    How It Works
                </a>
            </div>
        </div>

        <div class="hero-visual">
            <div class="hero-car-wrapper">
                <!-- Floating badges -->
                <div class="hero-float hero-float-1">
                    <div class="float-icon float-icon-green">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                    Verified Fleet
                </div>
                <div class="hero-float hero-float-2">
                    <div class="float-icon float-icon-amber">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    </div>
                    4.9 Rating
                </div>

                <div class="hero-car-card">
                    <div class="hero-car-image">
                        <!-- Sporty car SVG -->
                        <svg class="hero-car-svg" viewBox="0 0 500 200" xmlns="http://www.w3.org/2000/svg">
                            <defs>
                                <linearGradient id="carGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" style="stop-color:#6366f1"/>
                                    <stop offset="100%" style="stop-color:#a78bfa"/>
                                </linearGradient>
                                <linearGradient id="windowGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" style="stop-color:#c7d2fe"/>
                                    <stop offset="100%" style="stop-color:#818cf8"/>
                                </linearGradient>
                                <filter id="carShadow" x="-10%" y="-10%" width="120%" height="140%">
                                    <feDropShadow dx="0" dy="8" stdDeviation="8" flood-color="#6366f1" flood-opacity="0.3"/>
                                </filter>
                            </defs>
                            <g filter="url(#carShadow)">
                                <!-- Car body -->
                                <path d="M60,130 Q60,100 90,100 L150,100 L180,60 Q185,55 195,55 L310,55 Q320,55 325,60 L370,100 L420,100 Q450,100 450,130 L450,140 Q450,150 440,150 L70,150 Q60,150 60,140 Z" fill="url(#carGrad)"/>
                                <!-- Windows -->
                                <path d="M188,65 L170,95 L240,95 L240,65 Q240,62 237,62 L191,62 Q189,62 188,65 Z" fill="url(#windowGrad)" opacity="0.9"/>
                                <path d="M248,62 L248,95 L350,95 L320,65 Q318,62 315,62 Z" fill="url(#windowGrad)" opacity="0.9"/>
                                <!-- Headlights -->
                                <rect x="430" y="108" width="18" height="12" rx="4" fill="#fbbf24" opacity="0.9"/>
                                <rect x="62" y="108" width="18" height="12" rx="4" fill="#ef4444" opacity="0.7"/>
                                <!-- Door line -->
                                <line x1="245" y1="62" x2="245" y2="145" stroke="#4f46e5" stroke-width="1.5" opacity="0.4"/>
                                <!-- Front bumper detail -->
                                <rect x="400" y="130" width="50" height="4" rx="2" fill="#4f46e5" opacity="0.5"/>
                                <!-- Side detail -->
                                <path d="M100,125 L400,125" stroke="#4f46e5" stroke-width="1.5" opacity="0.3"/>
                                <!-- Side mirror -->
                                <rect x="165" y="88" width="12" height="8" rx="3" fill="url(#carGrad)"/>
                            </g>
                            <!-- Wheels -->
                            <circle cx="145" cy="150" r="28" fill="#1e293b"/>
                            <circle cx="145" cy="150" r="18" fill="#334155"/>
                            <circle cx="145" cy="150" r="10" fill="#475569"/>
                            <circle cx="145" cy="150" r="4" fill="#64748b"/>
                            <!-- Wheel spokes -->
                            <line x1="145" y1="132" x2="145" y2="140" stroke="#64748b" stroke-width="2"/>
                            <line x1="145" y1="160" x2="145" y2="168" stroke="#64748b" stroke-width="2"/>
                            <line x1="127" y1="150" x2="135" y2="150" stroke="#64748b" stroke-width="2"/>
                            <line x1="155" y1="150" x2="163" y2="150" stroke="#64748b" stroke-width="2"/>

                            <circle cx="375" cy="150" r="28" fill="#1e293b"/>
                            <circle cx="375" cy="150" r="18" fill="#334155"/>
                            <circle cx="375" cy="150" r="10" fill="#475569"/>
                            <circle cx="375" cy="150" r="4" fill="#64748b"/>
                            <line x1="375" y1="132" x2="375" y2="140" stroke="#64748b" stroke-width="2"/>
                            <line x1="375" y1="160" x2="375" y2="168" stroke="#64748b" stroke-width="2"/>
                            <line x1="357" y1="150" x2="365" y2="150" stroke="#64748b" stroke-width="2"/>
                            <line x1="385" y1="150" x2="393" y2="150" stroke="#64748b" stroke-width="2"/>
                            <!-- Ground reflection -->
                            <ellipse cx="260" cy="182" rx="180" ry="6" fill="url(#carGrad)" opacity="0.08"/>
                        </svg>
                    </div>

                    <div class="hero-car-info">
                        <div class="hero-car-stat">
                            <div class="hero-car-stat-value">320</div>
                            <div class="hero-car-stat-label">Horsepower</div>
                        </div>
                        <div class="hero-car-stat">
                            <div class="hero-car-stat-value">4.2s</div>
                            <div class="hero-car-stat-label">0-100 km/h</div>
                        </div>
                        <div class="hero-car-stat">
                            <div class="hero-car-stat-value">&euro;89</div>
                            <div class="hero-car-stat-label">Per Day</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS -->
<div class="hero-stats">
    <div class="hero-stats-inner">
        <div class="hero-stat-item">
            <div class="hero-stat-number" data-count="150" data-suffix="+">0</div>
            <div class="hero-stat-text">Premium Vehicles</div>
        </div>
        <div class="hero-stat-item">
            <div class="hero-stat-number" data-count="12" data-suffix="">0</div>
            <div class="hero-stat-text">City Locations</div>
        </div>
        <div class="hero-stat-item">
            <div class="hero-stat-number" data-count="50" data-suffix="K+">0</div>
            <div class="hero-stat-text">Happy Customers</div>
        </div>
        <div class="hero-stat-item">
            <div class="hero-stat-number" data-count="99" data-suffix="%">0</div>
            <div class="hero-stat-text">Satisfaction Rate</div>
        </div>
    </div>
</div>

