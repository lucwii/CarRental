<!-- HOW IT WORKS -->
<section id="how-it-works" class="section section-dark">
    <div class="section-container">
        <div class="section-header">
            <div class="section-label">Simple Process</div>
            <h2 class="section-title">How It Works</h2>
            <p class="section-subtitle">Rent your dream car in three easy steps. No hassle, no hidden fees.</p>
        </div>

        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">1</div>
                <h3 class="step-title">Choose Your Car</h3>
                <p class="step-text">Browse our fleet and pick the vehicle that suits your style and budget.</p>
            </div>
            <div class="step-card">
                <div class="step-number">2</div>
                <h3 class="step-title">Book Online</h3>
                <p class="step-text">Select your dates, review the details, and confirm your reservation in seconds.</p>
            </div>
            <div class="step-card">
                <div class="step-number">3</div>
                <h3 class="step-title">Hit the Road</h3>
                <p class="step-text">Pick up the keys from your nearest location and enjoy the ride.</p>
            </div>
        </div>
    </div>
</section>

