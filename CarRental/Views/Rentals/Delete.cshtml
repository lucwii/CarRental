@model CarRental.Models.Domain.Rental
@{
    ViewData["Title"] = "Cancel Rental";
    var days = (Model.EndDate - Model.StartDate).Days;
}

@await Html.PartialAsync("_Navbar")

<section class="auth-page">
    <div class="auth-bg-grid"></div>
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-logo">
                    <div class="nav-logo-icon" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                        </svg>
                    </div>
                </div>
                <h1 class="auth-title">Cancel Rental</h1>
                <p class="auth-subtitle">Are you sure you want to cancel this rental?</p>
            </div>

            <div class="customer-delete-info">
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Vehicle</span>
                    <span class="customer-delete-value">@Model.Car.Brand.Name @Model.Car.Model</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Pickup</span>
                    <span class="customer-delete-value">@Model.StartDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Return</span>
                    <span class="customer-delete-value">@Model.EndDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Duration</span>
                    <span class="customer-delete-value">@days day@(days != 1 ? "s" : "")</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Total Price</span>
                    <span class="customer-delete-value">&euro;@Model.TotalPrice</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Status</span>
                    <span class="customer-delete-value">
                        <span class="table-status status-@Model.Status.ToLower()">@Model.Status</span>
                    </span>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="margin-top: 1.5rem;">
                <button type="submit" class="auth-btn" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                    </svg>
                    Yes, Cancel Rental
                </button>
            </form>

            <div class="auth-divider"><span></span></div>

            <div class="auth-footer">
                <p><a asp-controller="Rentals" asp-action="Index" class="auth-link">No, go back</a></p>
            </div>
        </div>
    </div>
</section>
