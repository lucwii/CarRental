@model CarRental.Models.ViewModels.RentalCreateViewModel
@{
    ViewData["Title"] = "Rent a Car";
}

@await Html.PartialAsync("_Navbar")

<section class="auth-page" style="min-height: 100vh; padding-top: 7rem;">
    <div class="auth-bg-grid"></div>
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-container" style="max-width: 560px;">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-logo">
                    <div class="nav-logo-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 17h14M5 17a2 2 0 01-2-2V9a2 2 0 012-2h1l2-3h8l2 3h1a2 2 0 012 2v6a2 2 0 01-2 2M9 17a2 2 0 100-4 2 2 0 000 4zM15 17a2 2 0 100-4 2 2 0 000 4z"/>
                        </svg>
                    </div>
                </div>
                <h1 class="auth-title">Rent a Car</h1>
                <p class="auth-subtitle">Choose your car and dates</p>
            </div>

            <form asp-action="Create" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>

                <!-- Car Selection -->
                <div class="auth-field">
                    <label asp-for="CarId" class="auth-label">Select Vehicle</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 17h14M5 17a2 2 0 01-2-2V9a2 2 0 012-2h1l2-3h8l2 3h1a2 2 0 012 2v6a2 2 0 01-2 2M9 17a2 2 0 100-4 2 2 0 000 4zM15 17a2 2 0 100-4 2 2 0 000 4z"/>
                        </svg>
                        <select asp-for="CarId" class="auth-input" style="padding-left: 2.75rem; appearance: none; cursor: pointer;">
                            <option value="">-- Choose a car --</option>
                            @if (Model.AvailableCars != null)
                            {
                                @foreach (var car in Model.AvailableCars)
                                {
                                    <option value="@car.Id" data-price="@car.DailyPrice">@car.Brand.Name @car.Model (@car.Year) — &euro;@car.DailyPrice/day</option>
                                }
                            }
                        </select>
                    </div>
                    <span asp-validation-for="CarId" class="auth-field-error"></span>
                </div>

                <!-- Start Date -->
                <div class="auth-field">
                    <label asp-for="StartDate" class="auth-label">Pickup Date</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        <input asp-for="StartDate" type="date" class="auth-input" id="startDate" />
                    </div>
                    <span asp-validation-for="StartDate" class="auth-field-error"></span>
                </div>

                <!-- End Date -->
                <div class="auth-field">
                    <label asp-for="EndDate" class="auth-label">Return Date</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        <input asp-for="EndDate" type="date" class="auth-input" id="endDate" />
                    </div>
                    <span asp-validation-for="EndDate" class="auth-field-error"></span>
                </div>

                <!-- Price Preview -->
                <div class="rental-price-preview" id="pricePreview" style="display: none;">
                    <div class="rental-price-preview-label">Estimated Total</div>
                    <div class="rental-price-preview-value" id="priceValue">&euro;0</div>
                    <div class="rental-price-preview-detail" id="priceDetail"></div>
                </div>

                <button type="submit" class="auth-btn">
                    Confirm Rental
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 6L9 17l-5-5"/>
                    </svg>
                </button>
            </form>

            <div class="auth-divider"><span></span></div>

            <div class="auth-footer">
                <p><a asp-action="Index" class="auth-link">Back to My Rentals</a></p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        var carSelect = document.getElementById('CarId');
        var startDate = document.getElementById('startDate');
        var endDate = document.getElementById('endDate');
        var preview = document.getElementById('pricePreview');
        var priceValue = document.getElementById('priceValue');
        var priceDetail = document.getElementById('priceDetail');

        function updatePrice() {
            var selected = carSelect.options[carSelect.selectedIndex];
            var price = selected ? selected.getAttribute('data-price') : null;
            var start = startDate.value ? new Date(startDate.value) : null;
            var end = endDate.value ? new Date(endDate.value) : null;

            if (price && start && end && end > start) {
                var days = Math.round((end - start) / (1000 * 60 * 60 * 24));
                var total = parseFloat(price) * days;
                priceValue.textContent = '€' + total.toFixed(0);
                priceDetail.textContent = '€' + price + ' × ' + days + ' day' + (days !== 1 ? 's' : '');
                preview.style.display = 'block';
            } else {
                preview.style.display = 'none';
            }
        }

        carSelect.addEventListener('change', updatePrice);
        startDate.addEventListener('change', updatePrice);
        endDate.addEventListener('change', updatePrice);
        updatePrice();
    });
    </script>
}
