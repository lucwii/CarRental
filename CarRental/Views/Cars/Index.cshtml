@model IEnumerable<CarRental.Models.Domain.Car>
@{
    ViewData["Title"] = "Our Fleet";
}

@await Html.PartialAsync("_Navbar")

<!-- PAGE HEADER -->
<section class="cars-page-header">
    <div class="cars-header-bg-grid"></div>
    <div class="cars-header-glow"></div>
    <div class="section-container" style="position: relative; z-index: 2;">
        <div class="cars-header-content reveal">
            <div class="section-label" style="background: rgba(99,102,241,0.15); border-color: rgba(99,102,241,0.25); color: #818cf8;">Our Fleet</div>
            <h1 class="section-title" style="color: var(--white); font-size: 3.5rem;">Find Your Perfect Ride</h1>
            <p class="section-subtitle" style="color: var(--gray-light);">Browse @Model.Count() premium vehicles ready for your next adventure.</p>
        </div>

        <!-- FILTERS -->
        <div class="cars-filters reveal">
            <div class="filter-group">
                <label class="filter-label">Brand</label>
                <select class="filter-select" id="filterBrand">
                    <option value="">All Brands</option>
                    @foreach (var brand in Model.Select(c => c.Brand.Name).Distinct().OrderBy(b => b))
                    {
                        <option value="@brand">@brand</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">Fuel Type</label>
                <select class="filter-select" id="filterFuel">
                    <option value="">All Types</option>
                    @foreach (var fuel in Model.Select(c => c.FuelType).Distinct().OrderBy(f => f))
                    {
                        <option value="@fuel">@fuel</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">Seats</label>
                <select class="filter-select" id="filterSeats">
                    <option value="">Any</option>
                    @foreach (var seats in Model.Select(c => c.Seats).Distinct().OrderBy(s => s))
                    {
                        <option value="@seats">@seats Seats</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">Availability</label>
                <select class="filter-select" id="filterAvail">
                    <option value="">All</option>
                    <option value="true">Available</option>
                    <option value="false">Unavailable</option>
                </select>
            </div>
        </div>
    </div>
</section>

<!-- CARS GRID -->
<section class="section section-light" style="padding-top: 4rem;">
    <div class="section-container">
        <div class="cars-results-bar">
            <span class="cars-results-count" id="resultsCount">Showing @Model.Count() vehicles</span>
        </div>

        <div class="cars-grid" id="carsGrid">
            @foreach (var car in Model)
            {
                <div class="car-card"
                     data-brand="@car.Brand.Name"
                     data-fuel="@car.FuelType"
                     data-seats="@car.Seats"
                     data-available="@car.IsAvailable.ToString().ToLower()">
                    <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id" class="car-card-link">
                        <div class="car-card-image">
                            @if (car.IsAvailable)
                            {
                                <span class="car-card-badge badge-available">Available</span>
                            }
                            else
                            {
                                <span class="car-card-badge badge-unavailable">Rented</span>
                            }
                            @if (!string.IsNullOrEmpty(car.ImageUrl))
                            {
                                <img src="@car.ImageUrl" alt="@car.Brand.Name @car.Model" class="car-card-img"/>
                            }
                            else
                            {
                                <div class="car-card-placeholder">
                                    <svg viewBox="0 0 300 140" xmlns="http://www.w3.org/2000/svg">
                                        <defs><linearGradient id="cpg-@car.Id" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#6366f1"/><stop offset="100%" style="stop-color:#8b5cf6"/></linearGradient></defs>
                                        <path d="M35,88 Q35,68 50,68 L98,68 L118,40 Q121,35 128,35 L198,35 Q205,35 208,40 L238,68 L270,68 Q290,68 290,88 L290,93 Q290,100 282,100 L48,100 Q35,100 35,93 Z" fill="url(#cpg-@car.Id)"/>
                                        <path d="M123,40 L110,64 L160,64 L160,40 Q160,38 158,38 L125,38 Q124,38 123,40 Z" fill="#c7d2fe" opacity="0.8"/>
                                        <path d="M165,38 L165,64 L225,64 L205,42 Q204,38 201,38 Z" fill="#c7d2fe" opacity="0.8"/>
                                        <circle cx="95" cy="100" r="18" fill="#1e1b4b"/><circle cx="95" cy="100" r="11" fill="#312e81"/><circle cx="95" cy="100" r="5" fill="#4338ca"/>
                                        <circle cx="238" cy="100" r="18" fill="#1e1b4b"/><circle cx="238" cy="100" r="11" fill="#312e81"/><circle cx="238" cy="100" r="5" fill="#4338ca"/>
                                    </svg>
                                </div>
                            }
                        </div>
                        <div class="car-card-body">
                            <div class="car-card-brand">@car.Brand.Name</div>
                            <div class="car-card-name">@car.Brand.Name @car.Model</div>
                            <div class="car-card-specs">
                                <span class="car-spec">
                                    <span class="car-spec-icon">&#9971;</span> @car.FuelType
                                </span>
                                <span class="car-spec">
                                    <span class="car-spec-icon">&#128101;</span> @car.Seats Seats
                                </span>
                                <span class="car-spec">
                                    <span class="car-spec-icon">&#128197;</span> @car.Year
                                </span>
                            </div>
                            <div class="car-card-footer">
                                <div class="car-price">
                                    <span class="car-price-value">&euro;@car.DailyPrice</span>
                                    <span class="car-price-period">/day</span>
                                </div>
                                <span class="btn-rent">View Details</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="cars-empty">
                <div class="cars-empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                    </svg>
                </div>
                <h3 class="cars-empty-title">No vehicles found</h3>
                <p class="cars-empty-text">Check back soon for new additions to our fleet.</p>
            </div>
        }
    </div>
</section>

<!-- FOOTER -->
<footer class="landing-footer">
    <div class="section-container">
        <div class="footer-bottom" style="border: none; padding-top: 0;">
            <span class="footer-copy">&copy; 2026 CarRental. All rights reserved.</span>
            <div class="footer-socials">
                <a href="#" class="footer-social">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 4.557a9.83 9.83 0 01-2.828.775 4.932 4.932 0 002.165-2.724 9.864 9.864 0 01-3.127 1.195 4.916 4.916 0 00-8.384 4.482A13.944 13.944 0 011.671 3.149a4.916 4.916 0 001.523 6.574 4.897 4.897 0 01-2.229-.616v.062a4.917 4.917 0 003.946 4.827 4.902 4.902 0 01-2.224.084 4.918 4.918 0 004.588 3.417A9.867 9.867 0 010 19.54a13.94 13.94 0 007.548 2.212c9.057 0 14.01-7.503 14.01-14.01 0-.213-.005-.425-.014-.636A10.012 10.012 0 0024 4.557z"/></svg>
                </a>
                <a href="#" class="footer-social">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
            </div>
        </div>
    </div>
</footer>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    var filterBrand = document.getElementById('filterBrand');
    var filterFuel = document.getElementById('filterFuel');
    var filterSeats = document.getElementById('filterSeats');
    var filterAvail = document.getElementById('filterAvail');
    var cards = document.querySelectorAll('#carsGrid .car-card');
    var resultsCount = document.getElementById('resultsCount');

    function applyFilters() {
        var brand = filterBrand.value;
        var fuel = filterFuel.value;
        var seats = filterSeats.value;
        var avail = filterAvail.value;
        var visible = 0;

        cards.forEach(function (card) {
            var show = true;
            if (brand && card.dataset.brand !== brand) show = false;
            if (fuel && card.dataset.fuel !== fuel) show = false;
            if (seats && card.dataset.seats !== seats) show = false;
            if (avail && card.dataset.available !== avail) show = false;

            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        resultsCount.textContent = 'Showing ' + visible + ' vehicle' + (visible !== 1 ? 's' : '');
    }

    filterBrand.addEventListener('change', applyFilters);
    filterFuel.addEventListener('change', applyFilters);
    filterSeats.addEventListener('change', applyFilters);
    filterAvail.addEventListener('change', applyFilters);
});
</script>
}
