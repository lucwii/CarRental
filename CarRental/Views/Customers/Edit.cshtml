@model CarRental.Models.Domain.Customer
@{
    ViewData["Title"] = $"Edit {Model.FullName}";
}

@await Html.PartialAsync("_Navbar")

<section class="auth-page">
    <div class="auth-bg-grid"></div>
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-logo">
                    <div class="nav-logo-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                    </div>
                </div>
                <h1 class="auth-title">Edit Customer</h1>
                <p class="auth-subtitle">Update profile for @Model.FullName</p>
            </div>

            <form asp-action="Edit" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserId" />

                <div class="auth-field">
                    <label asp-for="FullName" class="auth-label">Full Name</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                        <input asp-for="FullName" class="auth-input" />
                    </div>
                    <span asp-validation-for="FullName" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="PhoneNumber" class="auth-label">Phone Number</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                        </svg>
                        <input asp-for="PhoneNumber" class="auth-input" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="DrivingLicenseNumber" class="auth-label">Driving License Number</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
                        </svg>
                        <input asp-for="DrivingLicenseNumber" class="auth-input" />
                    </div>
                    <span asp-validation-for="DrivingLicenseNumber" class="auth-field-error"></span>
                </div>

                <button type="submit" class="auth-btn">
                    Save Changes
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 6L9 17l-5-5"/>
                    </svg>
                </button>
            </form>

            <div class="auth-divider"><span></span></div>

            <div class="auth-footer">
                <p><a asp-action="Details" asp-route-id="@Model.Id" class="auth-link">Back to Details</a></p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
