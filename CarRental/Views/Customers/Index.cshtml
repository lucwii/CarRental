@model IEnumerable<CarRental.Models.Domain.Customer>
@{
    ViewData["Title"] = "Customers";
}

@await Html.PartialAsync("_AdminLayout")

<!-- PAGE HEADER -->
<section class="cars-page-header">
    <div class="cars-header-bg-grid"></div>
    <div class="cars-header-glow"></div>
    <div class="section-container" style="position: relative; z-index: 2;">
        <div class="cars-header-content reveal">
            <div class="section-label" style="background: rgba(99,102,241,0.15); border-color: rgba(99,102,241,0.25); color: #818cf8;">Management</div>
            <h1 class="section-title" style="color: var(--white); font-size: 3.5rem;">Customers</h1>
            <p class="section-subtitle" style="color: var(--gray-light);">@Model.Count() registered customers in the system.</p>
        </div>
        <div style="display: flex; justify-content: center; margin-top: 2rem;">
            <a asp-action="Create" class="btn-hero-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Add Customer
            </a>
        </div>
    </div>
</section>

<!-- CUSTOMERS GRID -->
<section class="section section-light" style="padding-top: 4rem;">
    <div class="section-container">
        <div class="cars-results-bar">
            <span class="cars-results-count">Showing @Model.Count() customer@(Model.Count() != 1 ? "s" : "")</span>
        </div>

        @if (Model.Any())
        {
            <div class="customers-grid">
                @foreach (var customer in Model)
                {
                    <a asp-action="Details" asp-route-id="@customer.Id" class="customer-card-link">
                        <div class="customer-card">
                            <div class="customer-card-avatar">
                                <span>@(customer.FullName.Length > 0 ? customer.FullName[0].ToString().ToUpper() : "?")</span>
                            </div>
                            <div class="customer-card-body">
                                <div class="customer-card-name">@customer.FullName</div>
                                <div class="customer-card-info">
                                    @if (!string.IsNullOrEmpty(customer.PhoneNumber))
                                    {
                                        <span class="customer-info-item">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                                            </svg>
                                            @customer.PhoneNumber
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(customer.DrivingLicenseNumber))
                                    {
                                        <span class="customer-info-item">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
                                            </svg>
                                            @customer.DrivingLicenseNumber
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="customer-card-stats">
                                <div class="customer-stat">
                                    <span class="customer-stat-value">@customer.Rentals.Count</span>
                                    <span class="customer-stat-label">Rentals</span>
                                </div>
                            </div>
                            <div class="customer-card-arrow">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 18l6-6-6-6"/>
                                </svg>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="cars-empty">
                <div class="cars-empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    </svg>
                </div>
                <h3 class="cars-empty-title">No customers yet</h3>
                <p class="cars-empty-text">Customers will appear here once they register.</p>
            </div>
        }
    </div>
</section>

<!-- FOOTER -->
<footer class="landing-footer">
    <div class="section-container">
        <div class="footer-bottom" style="border: none; padding-top: 0;">
            <span class="footer-copy">&copy; 2026 CarRental. All rights reserved.</span>
        </div>
    </div>
</footer>
