@model CarRental.Models.Domain.Customer
@{
    ViewData["Title"] = Model.FullName;
    var activeRentals = Model.Rentals.Count(r => r.Status == "Active" || r.Status == "Pending");
    var completedRentals = Model.Rentals.Count(r => r.Status == "Completed");
    var totalSpent = Model.Rentals.Where(r => r.Status == "Completed").Sum(r => r.TotalPrice);
}

@await Html.PartialAsync("_Navbar")

<!-- DETAILS HERO -->
<section class="details-hero">
    <div class="cars-header-bg-grid"></div>
    <div class="cars-header-glow"></div>
    <div class="section-container" style="position: relative; z-index: 2;">
        <!-- Breadcrumb -->
        <div class="details-breadcrumb reveal">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            <a asp-controller="Customers" asp-action="Index">Customers</a>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            <span>@Model.FullName</span>
        </div>

        <div class="details-grid">
            <!-- Left: Customer Avatar Card -->
            <div class="details-image-section reveal">
                <div class="details-image-card" style="flex-direction: column; gap: 1.5rem;">
                    <div class="customer-detail-avatar">
                        <span>@(Model.FullName.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "?")</span>
                    </div>
                    <div style="text-align: center;">
                        <div style="font-size: 1.5rem; font-weight: 800; color: var(--white); margin-bottom: 0.25rem;">@Model.FullName</div>
                        <div style="font-size: 0.9rem; color: var(--gray-light);">Customer #@Model.Id</div>
                    </div>
                </div>
            </div>

            <!-- Right: Customer Info -->
            <div class="details-info-section reveal">
                <h1 class="details-title">@Model.FullName</h1>

                <!-- Specs Grid -->
                <div class="details-specs-grid">
                    <div class="details-spec">
                        <div class="details-spec-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                            </svg>
                        </div>
                        <div>
                            <div class="details-spec-label">Phone</div>
                            <div class="details-spec-value">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)</div>
                        </div>
                    </div>
                    <div class="details-spec">
                        <div class="details-spec-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
                            </svg>
                        </div>
                        <div>
                            <div class="details-spec-label">Driving License</div>
                            <div class="details-spec-value">@(string.IsNullOrEmpty(Model.DrivingLicenseNumber) ? "Not provided" : Model.DrivingLicenseNumber)</div>
                        </div>
                    </div>
                    <div class="details-spec">
                        <div class="details-spec-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <div>
                            <div class="details-spec-label">User ID</div>
                            <div class="details-spec-value" style="font-size: 0.8rem; word-break: break-all;">@(string.IsNullOrEmpty(Model.UserId) ? "No account" : Model.UserId)</div>
                        </div>
                    </div>
                    <div class="details-spec">
                        <div class="details-spec-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                            </svg>
                        </div>
                        <div>
                            <div class="details-spec-label">Total Spent</div>
                            <div class="details-spec-value">&euro;@totalSpent</div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="details-actions">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-hero-primary" style="width: 100%; justify-content: center;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                        Edit Customer
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-hero-secondary" style="width: 100%; justify-content: center; border-color: rgba(239, 68, 68, 0.3); color: #fca5a5;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                        </svg>
                        Delete Customer
                    </a>
                    <a asp-action="Index" class="btn-hero-secondary" style="width: 100%; justify-content: center;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 12H5M12 19l-7-7 7-7"/>
                        </svg>
                        Back to Customers
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS -->
<section class="section section-light">
    <div class="section-container">
        <div class="details-stats-row reveal">
            <div class="details-stat-card">
                <div class="details-stat-icon" style="background: rgba(34, 197, 94, 0.1);">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                </div>
                <div class="details-stat-info">
                    <div class="details-stat-number">@completedRentals</div>
                    <div class="details-stat-label">Completed</div>
                </div>
            </div>
            <div class="details-stat-card">
                <div class="details-stat-icon" style="background: rgba(99, 102, 241, 0.1);">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                </div>
                <div class="details-stat-info">
                    <div class="details-stat-number">@activeRentals</div>
                    <div class="details-stat-label">Active</div>
                </div>
            </div>
            <div class="details-stat-card">
                <div class="details-stat-icon" style="background: rgba(245, 158, 11, 0.1);">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                </div>
                <div class="details-stat-info">
                    <div class="details-stat-number">@Model.Rentals.Count</div>
                    <div class="details-stat-label">Total Rentals</div>
                </div>
            </div>
            <div class="details-stat-card">
                <div class="details-stat-icon" style="background: rgba(236, 72, 153, 0.1);">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                    </svg>
                </div>
                <div class="details-stat-info">
                    <div class="details-stat-number">&euro;@totalSpent</div>
                    <div class="details-stat-label">Total Spent</div>
                </div>
            </div>
        </div>

        @if (Model.Rentals.Any())
        {
            <div class="details-rentals-section reveal">
                <h2 class="section-title" style="font-size: 1.75rem; margin-bottom: 1.5rem;">Rental History</h2>
                <div class="details-table-wrapper">
                    <table class="details-table">
                        <thead>
                            <tr>
                                <th>Vehicle</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Total Price</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rental in Model.Rentals.OrderByDescending(r => r.StartDate))
                            {
                                <tr>
                                    <td>
                                        <div class="table-customer">
                                            <div class="table-customer-avatar">@rental.Car.Brand.Name[0]</div>
                                            @rental.Car.Brand.Name @rental.Car.Model
                                        </div>
                                    </td>
                                    <td>@rental.StartDate.ToString("MMM dd, yyyy")</td>
                                    <td>@rental.EndDate.ToString("MMM dd, yyyy")</td>
                                    <td><strong>&euro;@rental.TotalPrice</strong></td>
                                    <td>
                                        <span class="table-status status-@rental.Status.ToLower()">@rental.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>

<!-- FOOTER -->
<footer class="landing-footer">
    <div class="section-container">
        <div class="footer-bottom" style="border: none; padding-top: 0;">
            <span class="footer-copy">&copy; 2026 CarRental. All rights reserved.</span>
        </div>
    </div>
</footer>
