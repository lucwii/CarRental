@model CarRental.Models.Domain.Customer
@{
    ViewData["Title"] = $"Delete {Model.FullName}";
}

@await Html.PartialAsync("_AdminLayout")

<section class="auth-page">
    <div class="auth-bg-grid"></div>
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-logo">
                    <div class="nav-logo-icon" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                        </svg>
                    </div>
                </div>
                <h1 class="auth-title">Delete Customer</h1>
                <p class="auth-subtitle">Are you sure you want to delete this customer?</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="auth-error-summary">
                    @TempData["Error"]
                </div>
            }

            <div class="customer-delete-info">
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Name</span>
                    <span class="customer-delete-value">@Model.FullName</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Phone</span>
                    <span class="customer-delete-value">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">License</span>
                    <span class="customer-delete-value">@(string.IsNullOrEmpty(Model.DrivingLicenseNumber) ? "Not provided" : Model.DrivingLicenseNumber)</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Rentals</span>
                    <span class="customer-delete-value">@Model.Rentals.Count rental@(Model.Rentals.Count != 1 ? "s" : "")</span>
                </div>
            </div>

            @if (Model.Rentals.Any())
            {
                <div class="auth-error-summary" style="margin-top: 1rem;">
                    This customer has @Model.Rentals.Count rental(s) and cannot be deleted.
                </div>
            }

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="margin-top: 1.5rem;">
                <button type="submit" class="auth-btn" style="background: linear-gradient(135deg, #ef4444, #dc2626);" @(Model.Rentals.Any() ? "disabled style=opacity:0.5;cursor:not-allowed;background:linear-gradient(135deg,#ef4444,#dc2626);" : "")>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                    </svg>
                    Confirm Delete
                </button>
            </form>

            <div class="auth-divider"><span></span></div>

            <div class="auth-footer">
                <p><a asp-action="Details" asp-route-id="@Model.Id" class="auth-link">Cancel, go back</a></p>
            </div>
        </div>
    </div>
</section>
