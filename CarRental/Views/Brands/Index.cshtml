@model IEnumerable<CarRental.Models.Domain.Brand>
@{
    ViewData["Title"] = "Our Brands";
}

@await Html.PartialAsync("_Navbar")

<!-- PAGE HEADER -->
<section class="cars-page-header">
    <div class="cars-header-bg-grid"></div>
    <div class="cars-header-glow"></div>
    <div class="section-container" style="position: relative; z-index: 2;">
        <div class="cars-header-content reveal">
            <div class="section-label" style="background: rgba(99,102,241,0.15); border-color: rgba(99,102,241,0.25); color: #818cf8;">Our Partners</div>
            <h1 class="section-title" style="color: var(--white); font-size: 3.5rem;">Premium Brands</h1>
            <p class="section-subtitle" style="color: var(--gray-light);">We partner with @Model.Count() world-class manufacturers to bring you the finest vehicles.</p>
        </div>
    </div>
</section>

<!-- BRANDS GRID -->
<section class="section section-light" style="padding-top: 4rem;">
    <div class="section-container">
        <div class="cars-results-bar">
            <span class="cars-results-count">@Model.Count() brands available</span>
        </div>

        <div class="brands-grid">
            @foreach (var brand in Model)
            {
                <a asp-controller="Brands" asp-action="Details" asp-route-id="@brand.Id" class="brand-card">
                    <div class="brand-card-header">
                        <div class="brand-card-logo">
                            @if (!string.IsNullOrEmpty(brand.LogoUrl))
                            {
                                <img src="@brand.LogoUrl" alt="@brand.Name" class="brand-card-logo-img"/>
                            }
                            else
                            {
                                <span class="brand-card-logo-letter">@brand.Name[0]</span>
                            }
                        </div>
                        <div class="brand-card-arrow">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </div>
                    <div class="brand-card-body">
                        <h3 class="brand-card-name">@brand.Name</h3>
                        <div class="brand-card-country">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
                            </svg>
                            @brand.Country
                        </div>
                    </div>
                    <div class="brand-card-footer">
                        <div class="brand-card-stat">
                            <span class="brand-card-stat-value">@brand.Cars.Count</span>
                            <span class="brand-card-stat-label">Vehicles</span>
                        </div>
                        <div class="brand-card-stat">
                            <span class="brand-card-stat-value">@brand.Cars.Count(c => c.IsAvailable)</span>
                            <span class="brand-card-stat-label">Available</span>
                        </div>
                        <div class="brand-card-stat">
                            @if (brand.Cars.Any())
                            {
                                <span class="brand-card-stat-value">&euro;@brand.Cars.Min(c => c.DailyPrice)</span>
                            }
                            else
                            {
                                <span class="brand-card-stat-value">-</span>
                            }
                            <span class="brand-card-stat-label">From</span>
                        </div>
                    </div>
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="cars-empty">
                <div class="cars-empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                    </svg>
                </div>
                <h3 class="cars-empty-title">No brands found</h3>
                <p class="cars-empty-text">Check back soon for new brand partnerships.</p>
            </div>
        }
    </div>
</section>

<!-- FOOTER -->
<footer class="landing-footer">
    <div class="section-container">
        <div class="footer-bottom" style="border: none; padding-top: 0;">
            <span class="footer-copy">&copy; 2026 CarRental. All rights reserved.</span>
            <div class="footer-socials">
                <a href="#" class="footer-social">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 4.557a9.83 9.83 0 01-2.828.775 4.932 4.932 0 002.165-2.724 9.864 9.864 0 01-3.127 1.195 4.916 4.916 0 00-8.384 4.482A13.944 13.944 0 011.671 3.149a4.916 4.916 0 001.523 6.574 4.897 4.897 0 01-2.229-.616v.062a4.917 4.917 0 003.946 4.827 4.902 4.902 0 01-2.224.084 4.918 4.918 0 004.588 3.417A9.867 9.867 0 010 19.54a13.94 13.94 0 007.548 2.212c9.057 0 14.01-7.503 14.01-14.01 0-.213-.005-.425-.014-.636A10.012 10.012 0 0024 4.557z"/></svg>
                </a>
                <a href="#" class="footer-social">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
            </div>
        </div>
    </div>
</footer>
