@model CarRental.Models.Domain.Car
@{
    ViewData["Title"] = $"Edit {Model.Model}";
    var brands = (List<CarRental.Models.Domain.Brand>)ViewBag.Brands;
    var locations = (List<CarRental.Models.Domain.Location>)ViewBag.Locations;
}

@await Html.PartialAsync("_AdminLayout")

<section class="auth-page" style="min-height: 100vh; padding-top: 7rem;">
    <div class="auth-bg-grid"></div>
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-container" style="max-width: 560px;">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-logo">
                    <div class="nav-logo-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                    </div>
                </div>
                <h1 class="auth-title">Edit Car</h1>
                <p class="auth-subtitle">Update vehicle details</p>
            </div>

            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>
                <input type="hidden" asp-for="Id" />

                <!-- Brand -->
                <div class="auth-field">
                    <label asp-for="BrandId" class="auth-label">Brand</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/>
                        </svg>
                        <select asp-for="BrandId" class="auth-input" style="padding-left: 2.75rem; cursor: pointer;">
                            @foreach (var brand in brands)
                            {
                                <option value="@brand.Id">@brand.Name</option>
                            }
                        </select>
                    </div>
                    <span asp-validation-for="BrandId" class="auth-field-error"></span>
                </div>

                <!-- Model -->
                <div class="auth-field">
                    <label asp-for="Model" class="auth-label">Model</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 17h14M5 17a2 2 0 01-2-2V9a2 2 0 012-2h1l2-3h8l2 3h1a2 2 0 012 2v6a2 2 0 01-2 2"/>
                        </svg>
                        <input asp-for="Model" class="auth-input" />
                    </div>
                    <span asp-validation-for="Model" class="auth-field-error"></span>
                </div>

                <!-- Year & Seats -->
                <div class="admin-form-row">
                    <div class="auth-field" style="flex: 1;">
                        <label asp-for="Year" class="auth-label">Year</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
                            </svg>
                            <input asp-for="Year" type="number" class="auth-input" />
                        </div>
                        <span asp-validation-for="Year" class="auth-field-error"></span>
                    </div>
                    <div class="auth-field" style="flex: 1;">
                        <label asp-for="Seats" class="auth-label">Seats</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                            </svg>
                            <input asp-for="Seats" type="number" class="auth-input" />
                        </div>
                        <span asp-validation-for="Seats" class="auth-field-error"></span>
                    </div>
                </div>

                <!-- License Plate -->
                <div class="auth-field">
                    <label asp-for="LicensePlate" class="auth-label">License Plate</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="1" y="3" width="15" height="13" rx="2" ry="2"/><path d="M16 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2"/>
                        </svg>
                        <input asp-for="LicensePlate" class="auth-input" />
                    </div>
                    <span asp-validation-for="LicensePlate" class="auth-field-error"></span>
                </div>

                <!-- Daily Price & Fuel Type -->
                <div class="admin-form-row">
                    <div class="auth-field" style="flex: 1;">
                        <label asp-for="DailyPrice" class="auth-label">Price/Day (&euro;)</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                            </svg>
                            <input asp-for="DailyPrice" type="number" step="0.01" class="auth-input" />
                        </div>
                        <span asp-validation-for="DailyPrice" class="auth-field-error"></span>
                    </div>
                    <div class="auth-field" style="flex: 1;">
                        <label asp-for="FuelType" class="auth-label">Fuel Type</label>
                        <div class="auth-input-wrapper">
                            <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                            </svg>
                            <select asp-for="FuelType" class="auth-input" style="padding-left: 2.75rem; cursor: pointer;">
                                <option value="Benzin">Benzin</option>
                                <option value="Dizel">Dizel</option>
                                <option value="Hibrid">Hibrid</option>
                                <option value="Električni">Električni</option>
                            </select>
                        </div>
                        <span asp-validation-for="FuelType" class="auth-field-error"></span>
                    </div>
                </div>

                <!-- Location -->
                <div class="auth-field">
                    <label asp-for="LocationId" class="auth-label">Location</label>
                    <div class="auth-input-wrapper">
                        <svg class="auth-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
                        </svg>
                        <select asp-for="LocationId" class="auth-input" style="padding-left: 2.75rem; cursor: pointer;">
                            @foreach (var loc in locations)
                            {
                                <option value="@loc.Id">@loc.City — @loc.Address</option>
                            }
                        </select>
                    </div>
                    <span asp-validation-for="LocationId" class="auth-field-error"></span>
                </div>

                <!-- Available checkbox -->
                <div class="auth-options">
                    <label class="auth-checkbox">
                        <input asp-for="IsAvailable" type="checkbox" />
                        <span class="auth-checkmark"></span>
                        Available for rent
                    </label>
                </div>

                <button type="submit" class="auth-btn">
                    Save Changes
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 6L9 17l-5-5"/>
                    </svg>
                </button>
            </form>

            <div class="auth-divider"><span></span></div>

            <div class="auth-footer">
                <p><a asp-action="Index" class="auth-link">Back to Manage Cars</a></p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
