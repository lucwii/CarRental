@model IEnumerable<CarRental.Models.Domain.Brand>
@{
    ViewData["Title"] = "Manage Brands";
    var totalCars = Model.Sum(b => b.Cars.Count);
}

@await Html.PartialAsync("_Navbar")

<!-- PAGE HEADER -->
<section class="cars-page-header">
    <div class="cars-header-bg-grid"></div>
    <div class="cars-header-glow"></div>
    <div class="section-container" style="position: relative; z-index: 2;">
        <div class="cars-header-content reveal">
            <div class="section-label" style="background: rgba(99,102,241,0.15); border-color: rgba(99,102,241,0.25); color: #818cf8;">Admin Panel</div>
            <h1 class="section-title" style="color: var(--white); font-size: 3.5rem;">Manage Brands</h1>
            <p class="section-subtitle" style="color: var(--gray-light);">@Model.Count() brands, @totalCars vehicles total.</p>
        </div>
        <div style="display: flex; justify-content: center; margin-top: 2rem;">
            <a href="/Admin/Brands/Create" class="btn-hero-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Add Brand
            </a>
        </div>
    </div>
</section>

<!-- BRANDS TABLE -->
<section class="section section-light" style="padding-top: 4rem;">
    <div class="section-container">
        @if (Model.Any())
        {
            <div class="details-table-wrapper">
                <table class="details-table">
                    <thead>
                        <tr>
                            <th>Brand</th>
                            <th>Country</th>
                            <th>Cars</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var brand in Model)
                        {
                            <tr>
                                <td>
                                    <div class="table-customer">
                                        <div class="table-customer-avatar">@brand.Name[0]</div>
                                        <strong>@brand.Name</strong>
                                    </div>
                                </td>
                                <td>@brand.Country</td>
                                <td><strong>@brand.Cars.Count</strong></td>
                                <td>
                                    <div class="rental-card-actions">
                                        <a href="/Admin/Brands/Edit/@brand.Id" class="rental-action-btn rental-action-edit" title="Edit">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                        </a>
                                        <a href="/Admin/Brands/Delete/@brand.Id" class="rental-action-btn rental-action-delete" title="Delete">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="cars-empty">
                <div class="cars-empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/>
                    </svg>
                </div>
                <h3 class="cars-empty-title">No brands yet</h3>
                <p class="cars-empty-text">Add your first brand to get started.</p>
            </div>
        }
    </div>
</section>

<!-- FOOTER -->
<footer class="landing-footer">
    <div class="section-container">
        <div class="footer-bottom" style="border: none; padding-top: 0;">
            <span class="footer-copy">&copy; 2026 CarRental. All rights reserved.</span>
        </div>
    </div>
</footer>
