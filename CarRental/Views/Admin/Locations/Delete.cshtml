@model CarRental.Models.Domain.Location
@{
    ViewData["Title"] = $"Delete {Model.City}";
}

@await Html.PartialAsync("_AdminLayout")

<section class="auth-page">
    <div class="auth-bg-grid"></div>
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-logo">
                    <div class="nav-logo-icon" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                        </svg>
                    </div>
                </div>
                <h1 class="auth-title">Delete Location</h1>
                <p class="auth-subtitle">Are you sure you want to delete this location?</p>
            </div>

            <div class="customer-delete-info">
                <div class="customer-delete-row">
                    <span class="customer-delete-label">City</span>
                    <span class="customer-delete-value">@Model.City</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Address</span>
                    <span class="customer-delete-value">@Model.Address</span>
                </div>
                <div class="customer-delete-row">
                    <span class="customer-delete-label">Cars</span>
                    <span class="customer-delete-value">@Model.Cars.Count vehicle@(Model.Cars.Count != 1 ? "s" : "")</span>
                </div>
            </div>

            @if (Model.Cars.Any())
            {
                <div class="auth-error-summary" style="margin-top: 1rem;">
                    This location has @Model.Cars.Count car(s) assigned. Deleting may fail if cars reference this location.
                </div>
            }

            <form action="/Admin/Locations/Delete/@Model.Id" method="post" style="margin-top: 1.5rem;">
                @Html.AntiForgeryToken()
                <button type="submit" class="auth-btn" style="background: linear-gradient(135deg, #ef4444, #dc2626);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                    </svg>
                    Yes, Delete Location
                </button>
            </form>

            <div class="auth-divider"><span></span></div>

            <div class="auth-footer">
                <p><a href="/Admin/Locations" class="auth-link">Cancel, go back</a></p>
            </div>
        </div>
    </div>
</section>
