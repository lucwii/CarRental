@model CarRental.Models.ViewModels.RentalAdminViewModel
@{
    ViewData["Title"] = "Manage Rentals";

    string BuildPageUrl(int p)
    {
        var qs = new List<string> { $"page={p}" };
        if (!string.IsNullOrEmpty(Model.StatusFilter)) qs.Add($"status={Uri.EscapeDataString(Model.StatusFilter)}");
        if (!string.IsNullOrEmpty(Model.CityFilter)) qs.Add($"city={Uri.EscapeDataString(Model.CityFilter)}");
        if (!string.IsNullOrEmpty(Model.SortBy)) qs.Add($"sortBy={Uri.EscapeDataString(Model.SortBy)}");
        return "/Admin/Rentals?" + string.Join("&", qs);
    }
}

@await Html.PartialAsync("_AdminLayout")

<!-- PAGE HEADER -->
<section class="cars-page-header">
    <div class="cars-header-bg-grid"></div>
    <div class="cars-header-glow"></div>
    <div class="section-container" style="position: relative; z-index: 2;">
        <div class="cars-header-content reveal">
            <div class="section-label" style="background: rgba(99,102,241,0.15); border-color: rgba(99,102,241,0.25); color: #818cf8;">Admin Panel</div>
            <h1 class="section-title" style="color: var(--white); font-size: 3.5rem;">Manage Rentals</h1>
            <p class="section-subtitle" style="color: var(--gray-light);">
                @Model.Rentals.Count of @(Model.TotalPages * Model.PageSize > 0 ? $"page {Model.CurrentPage}/{Model.TotalPages}" : "0") results.
            </p>
        </div>

        <!-- FILTERS -->
        <form method="get" asp-action="Index" class="cars-filters" style="margin-top: 2rem;">
            <div class="filter-group">
                <label class="filter-label">Status</label>
                <select name="status" class="filter-select" onchange="this.form.submit()">
                    <option value="">All Statuses</option>
                    @foreach (var s in Model.AvailableStatuses)
                    {
                        <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">City</label>
                <select name="city" class="filter-select" onchange="this.form.submit()">
                    <option value="">All Cities</option>
                    @foreach (var c in Model.AvailableCities)
                    {
                        <option value="@c" selected="@(Model.CityFilter == c)">@c</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">Sort By</label>
                <select name="sortBy" class="filter-select" onchange="this.form.submit()">
                    <option value="date_desc" selected="@(string.IsNullOrEmpty(Model.SortBy) || Model.SortBy == "date_desc")">Newest First</option>
                    <option value="date_asc" selected="@(Model.SortBy == "date_asc")">Oldest First</option>
                    <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Price: High → Low</option>
                    <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Price: Low → High</option>
                </select>
            </div>
        </form>
    </div>
</section>

<!-- RENTALS TABLE -->
<section class="section section-light" style="padding-top: 4rem;">
    <div class="section-container">
        @if (Model.Rentals.Any())
        {
            <div class="details-table-wrapper">
                <table class="details-table">
                    <thead>
                        <tr>
                            <th>Customer</th>
                            <th>Vehicle</th>
                            <th>Location</th>
                            <th>Dates</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rental in Model.Rentals)
                        {
                            <tr>
                                <td>
                                    <div class="table-customer">
                                        <div class="table-customer-avatar">@rental.Customer.FullName[0]</div>
                                        <div>
                                            <div style="font-weight: 700;">@rental.Customer.FullName</div>
                                            <div style="font-size: 0.78rem; color: var(--gray);">@rental.Customer.PhoneNumber</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div style="font-weight: 600;">@rental.Car.Brand.Name @rental.Car.Model</div>
                                    <div style="font-size: 0.78rem; color: var(--gray);">@rental.Car.LicensePlate</div>
                                </td>
                                <td>@rental.Car.Location.City</td>
                                <td>
                                    <div style="font-size: 0.85rem;">@rental.StartDate.ToString("MMM dd") — @rental.EndDate.ToString("MMM dd, yyyy")</div>
                                    <div style="font-size: 0.75rem; color: var(--gray);">@((rental.EndDate - rental.StartDate).Days) days</div>
                                </td>
                                <td><strong>&euro;@rental.TotalPrice</strong></td>
                                <td>
                                    <form method="post" asp-action="UpdateStatus" asp-route-id="@rental.Id" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="status" value="@Model.StatusFilter" />
                                        <input type="hidden" name="city" value="@Model.CityFilter" />
                                        <input type="hidden" name="sortBy" value="@Model.SortBy" />
                                        <input type="hidden" name="page" value="@Model.CurrentPage" />
                                        <select name="newStatus" class="status-select status-select-@rental.Status.ToLower()" onchange="this.form.submit()">
                                            @foreach (var st in Model.AvailableStatuses)
                                            {
                                                <option value="@st" selected="@(rental.Status == st)">@st</option>
                                            }
                                        </select>
                                    </form>
                                </td>
                                <td>
                                    <div class="rental-card-actions">
                                        <a href="/Admin/Rentals/Delete/@rental.Id" class="rental-action-btn rental-action-delete" title="Delete">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            @if (Model.TotalPages > 1)
            {
                <div class="admin-pagination">
                    @if (Model.CurrentPage > 1)
                    {
                        <a href="@BuildPageUrl(Model.CurrentPage - 1)" class="admin-page-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        </a>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a href="@BuildPageUrl(i)" class="admin-page-btn @(i == Model.CurrentPage ? "admin-page-active" : "")">@i</a>
                    }

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a href="@BuildPageUrl(Model.CurrentPage + 1)" class="admin-page-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        </a>
                    }
                </div>
            }
        }
        else
        {
            <div class="cars-empty">
                <div class="cars-empty-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                </div>
                <h3 class="cars-empty-title">No rentals found</h3>
                <p class="cars-empty-text">Try adjusting your filters or check back later.</p>
            </div>
        }
    </div>
</section>

<!-- FOOTER -->
<footer class="landing-footer">
    <div class="section-container">
        <div class="footer-bottom" style="border: none; padding-top: 0;">
            <span class="footer-copy">&copy; 2026 CarRental. All rights reserved.</span>
        </div>
    </div>
</footer>
