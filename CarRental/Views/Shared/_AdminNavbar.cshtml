@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<nav class="landing-nav scrolled" id="mainNav">
    <div class="nav-container">
        <a class="nav-logo" asp-controller="Home" asp-action="Index">
            <div class="nav-logo-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 17h14M5 17a2 2 0 01-2-2V9a2 2 0 012-2h1l2-3h8l2 3h1a2 2 0 012 2v6a2 2 0 01-2 2M9 17a2 2 0 100-4 2 2 0 000 4zM15 17a2 2 0 100-4 2 2 0 000 4z"/>
                </svg>
            </div>
            CarRental
        </a>
        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a href="/Admin/Cars" class="nav-active">Admin Panel</a></li>
            @if (SignInManager.IsSignedIn(User))
            {
                <li><a href="#" class="nav-link-login">Hello, @UserManager.GetUserName(User)</a></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="nav-cta" style="border:none;cursor:pointer;">Logout</button>
                    </form>
                </li>
            }
        </ul>
    </div>
</nav>
