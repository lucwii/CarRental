@{
    var path = ViewContext.HttpContext.Request.Path.ToString();
}

<aside class="admin-sidebar" id="adminSidebar">
    <div class="admin-sidebar-header">
        <a href="/Admin/Cars" class="admin-sidebar-logo">
            <div class="nav-logo-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
            </div>
            <span>Admin Panel</span>
        </a>
    </div>

    <nav class="admin-sidebar-nav">
        <div class="admin-sidebar-section">
            <div class="admin-sidebar-section-title">Fleet</div>
            <a href="/Admin/Cars" class="admin-sidebar-link @(path.StartsWith("/Admin/Cars") ? "admin-sidebar-active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 17h14M5 17a2 2 0 01-2-2V9a2 2 0 012-2h1l2-3h8l2 3h1a2 2 0 012 2v6a2 2 0 01-2 2M9 17a2 2 0 100-4 2 2 0 000 4zM15 17a2 2 0 100-4 2 2 0 000 4z"/>
                </svg>
                Cars
            </a>
            <a href="/Admin/Brands" class="admin-sidebar-link @(path.StartsWith("/Admin/Brands") ? "admin-sidebar-active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/>
                </svg>
                Brands
            </a>
            <a href="/Admin/Locations" class="admin-sidebar-link @(path.StartsWith("/Admin/Locations") ? "admin-sidebar-active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                Locations
            </a>
        </div>

        <div class="admin-sidebar-section">
            <div class="admin-sidebar-section-title">Business</div>
            <a href="/Admin/Rentals" class="admin-sidebar-link @(path.StartsWith("/Admin/Rentals") ? "admin-sidebar-active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Rentals
            </a>
        </div>

        <div class="admin-sidebar-section">
            <div class="admin-sidebar-section-title">Users</div>
            <a asp-controller="Customers" asp-action="Index" class="admin-sidebar-link @(path.StartsWith("/Customers") ? "admin-sidebar-active" : "")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
                Customers
            </a>
        </div>
    </nav>

    <div class="admin-sidebar-footer">
        <a asp-controller="Home" asp-action="Index" class="admin-sidebar-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Back to Site
        </a>
    </div>
</aside>
